#!/usr/bin/env bash
# scripts/discovery — Startet den Discovery Agent fuer Live-Meeting-Begleitung
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
AGENT_FILE="$PROJECT_ROOT/.claude/agents/discovery.md"
BRIEFING_DIR="$PROJECT_ROOT/briefings"
CLIENT_DIR="$PROJECT_ROOT/client"

if [[ ! -f "$AGENT_FILE" ]]; then
    echo "Fehler: Agent-Datei nicht gefunden: $AGENT_FILE"
    exit 1
fi

# Bestimme Session-Typ
BRIEFING_FILES=$(find "$BRIEFING_DIR" -name "discovery-*.md" ! -name "discovery-insights.md" -type f 2>/dev/null || true)

if [[ -n "$BRIEFING_FILES" ]]; then
    NEWEST_BRIEFING=$(ls -t "$BRIEFING_DIR"/discovery-*.md 2>/dev/null | grep -v "insights" | head -1)
    DYNAMIC_PROMPT="Der Agency Director hat dir ein Briefing hinterlegt. Lies es zuerst: $(basename "$NEWEST_BRIEFING")."
else
    DYNAMIC_PROMPT="Kein Briefing vom Agency Director vorhanden."
fi

# Pruefe ob bereits ein Briefing existiert
if [[ -f "$CLIENT_DIR/brief.md" ]]; then
    BRIEF_LINES=$(wc -l < "$CLIENT_DIR/brief.md")
    if [[ "$BRIEF_LINES" -gt 5 ]]; then
        DYNAMIC_PROMPT="$DYNAMIC_PROMPT Es gibt bereits ein Kunden-Briefing unter client/brief.md — lies es fuer Kontext."
    fi
fi

if [[ -f "$CLIENT_DIR/meeting-notes.md" ]]; then
    DYNAMIC_PROMPT="$DYNAMIC_PROMPT Fruehere Meeting-Notizen unter client/meeting-notes.md vorhanden."
fi

DYNAMIC_PROMPT="$DYNAMIC_PROMPT Lies CLAUDE.md und die relevanten client/-Dateien. Frage Andy, ob ein Meeting ansteht (Live-Begleitung) oder ob Meeting-Notizen verarbeitet werden sollen. Ich bin Andy."

cd "$PROJECT_ROOT"
exec claude --append-system-prompt "$(cat "$AGENT_FILE")" "$DYNAMIC_PROMPT"
