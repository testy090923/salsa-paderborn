---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Datenschutz – Salsa Paderborn">
  <div class="page-header">
    <h1>Datenschutz</h1>
  </div>

  <section class="section">
    <div class="container content-block">
      <p>Diese Seite wird in Kürze ergänzt.</p>
      <p>Bei Fragen wende dich an uns über die <a href="/kontakt">Kontaktseite</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .content-block {
    max-width: 600px;
  }

  .content-block p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .content-block a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .content-block a:hover {
    text-decoration: underline;
  }
</style>
