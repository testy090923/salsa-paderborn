---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeacherCard from '../../components/TeacherCard.astro';
import { sanityClient } from '../../lib/sanity';
import { allTeachersQuery } from '../../lib/queries';

const teachers = await sanityClient.fetch(allTeachersQuery) ?? [];
---

<BaseLayout title="Tanzlehrer:innen – Salsa Paderborn">
  <div class="page-header">
    <h1>Tanzlehrer:innen in Paderborn</h1>
    <p>Lerne von den Besten der lokalen Szene</p>
  </div>

  <section class="section">
    <div class="container">
      {teachers.length > 0 ? (
        <div class="teacher-list">
          {teachers.map((teacher: any) => (
            <TeacherCard teacher={teacher} />
          ))}
        </div>
      ) : (
        <p class="empty-state">Noch keine Lehrer:innen eingetragen. Schau bald wieder vorbei!</p>
      )}

      <!-- CTA card: static, not from CMS -->
      <article class="cta-card">
        <div class="cta-avatar">+</div>
        <div class="cta-content">
          <h2>Werde Teil der Community</h2>
          <p class="cta-styles">Dein Tanzstil</p>
          <p class="cta-bio">Du unterrichtest Salsa, Bachata oder Kizomba in Paderborn? Präsentiere dich auf dieser Plattform und erreiche neue Schüler:innen.</p>
          <a href="/kontakt" class="cta-link">Jetzt mitmachen &rarr;</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .teacher-list { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 1.5rem; }

  .empty-state {
    text-align: center;
    color: #888;
    font-size: 0.95rem;
    padding: 3rem 0;
  }

  .cta-card {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
    border: 2px dashed rgba(26, 26, 46, 0.2);
    margin-top: var(--space-lg);
  }

  .cta-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--color-neutral-light);
    color: #aaa;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-content { flex: 1; }
  .cta-content h2 { font-family: var(--font-heading); font-size: 1.3rem; margin-bottom: 2px; }
  .cta-styles { font-size: 0.9rem; color: var(--color-secondary-terracotta); font-weight: 600; margin-bottom: 2px; }
  .cta-bio { font-size: 0.95rem; color: #555; margin-bottom: var(--space-md); line-height: 1.5; }
  .cta-link { font-size: 0.9rem; font-weight: 600; color: var(--color-primary); text-decoration: none; }
  .cta-link:hover { text-decoration: underline; }

  @media (max-width: 600px) {
    .cta-card { flex-direction: column; align-items: center; text-align: center; }
  }
</style>
