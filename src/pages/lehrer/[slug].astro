---
/**
 * Dynamic teacher detail page.
 *
 * Replaces the static lehrer/nadia.astro page.
 * Fetches a single teacher from Sanity by slug, renders profile
 * with photo/avatar, bio (PortableText), courses list, and contact info.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SanityImage from '../../components/SanityImage.astro';
import { PortableText } from 'astro-portabletext';
import { sanityClient, urlFor } from '../../lib/sanity';
import { teacherBySlugQuery } from '../../lib/queries';

export async function getStaticPaths() {
  const teachers = await sanityClient.fetch(`*[_type == "teacher"]{ slug }`);
  return teachers
    .filter((item: any) => item.slug?.current)
    .map((item: any) => ({
      params: { slug: item.slug.current },
    }));
}

const { slug } = Astro.params;
const teacher = await sanityClient.fetch(teacherBySlugQuery, { slug });

if (!teacher) {
  return Astro.redirect('/lehrer');
}

// Level color coding (Brand Guide)
const levelColors: Record<string, string> = {
  'Anfänger': 'var(--color-success)',
  'Mittelstufe': 'var(--color-secondary-terracotta)',
  'Fortgeschritten': 'var(--color-primary)',
  'Alle': 'var(--color-info)',
};

// Schema.org Person structured data
const siteUrl = 'https://salsa-paderborn.de';
const teacherImageUrl = teacher.photo ? urlFor(teacher.photo)?.width(600).url() : undefined;

const teacherJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: teacher.name,
  url: `${siteUrl}/lehrer/${teacher.slug?.current}`,
  ...(teacherImageUrl && { image: teacherImageUrl }),
  jobTitle: 'Tanzlehrer:in',
  ...(teacher.website && { sameAs: teacher.website }),
  ...(teacher.school?.name && {
    worksFor: {
      '@type': 'Organization',
      name: teacher.school.name,
      ...(teacher.school.slug?.current && {
        url: `${siteUrl}/tanzschulen/${teacher.school.slug.current}`,
      }),
    },
  }),
  ...(teacher.styles?.length > 0 && {
    knowsAbout: teacher.styles,
  }),
};
---

<BaseLayout title={`${teacher.name} – Tanzlehrer:in in Paderborn`}>
  <script type="application/ld+json" set:html={JSON.stringify(teacherJsonLd)} slot="head" />
  <div class="page-header">
    <h1>{teacher.name}</h1>
    <p>{teacher.styles?.length > 0 ? teacher.styles.join(' & ') : 'Tanzlehrer:in'}</p>
  </div>

  <section class="section">
    <div class="container">
      <a href="/szene" class="back-link">&larr; Zurück zur Szene</a>

      <article class="profile">
        <!-- Profile photo -->
        <div class="profile-hero">
          {teacher.photo ? (
            <SanityImage
              source={teacher.photo}
              alt={teacher.name}
              width={600}
              class="profile-photo"
            />
          ) : (
            <div class="profile-avatar">{teacher.name.charAt(0)}</div>
          )}
        </div>

        <!-- Name + Styles subtitle -->
        <div class="profile-intro">
          <h2 class="profile-name">{teacher.name}</h2>
          {teacher.styles?.length > 0 && (
            <p class="profile-styles">{teacher.styles.join(' · ')}</p>
          )}
          {teacher.school?.name && (
            <p class="profile-school">
              {teacher.school.slug?.current ? (
                <a href={`/tanzschulen/${teacher.school.slug.current}`}>{teacher.school.name}</a>
              ) : (
                teacher.school.name
              )}
            </p>
          )}
        </div>

        <!-- Bio -->
        {teacher.bio && (
          <div class="profile-bio">
            <PortableText value={teacher.bio} />
          </div>
        )}

        <!-- Courses -->
        {teacher.courses && teacher.courses.length > 0 && (
          <div class="profile-section">
            <h3 class="profile-section-title">Aktuelle Kurse</h3>
            <div class="kurse-list">
              {teacher.courses.map((course: any) => (
                <a
                  href={course.slug?.current ? `/kurse/${course.slug.current}` : '#'}
                  class="kurs-item-link"
                >
                  <div class="kurs-item">
                    <div class="kurs-item-header">
                      <h4>{course.title}</h4>
                      {course.level && (
                        <span
                          class="kurs-level"
                          style={`background: ${levelColors[course.level] ?? '#666'}`}
                        >
                          {course.level}
                        </span>
                      )}
                    </div>
                    <p class="kurs-item-meta">
                      {course.schedule && <span>{course.schedule}</span>}
                      {course.location && <span> · {course.location}</span>}
                    </p>
                    {course.style && (
                      <span class="kurs-style">{course.style}</span>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Contact -->
        {(teacher.contact || teacher.website) && (
          <div class="profile-section">
            <h3 class="profile-section-title">Kontakt</h3>
            <div class="contact-links">
              {teacher.contact?.email && (
                <a href={`mailto:${teacher.contact.email}`} class="contact-link">
                  {teacher.contact.email}
                </a>
              )}
              {teacher.website && (
                <a href={teacher.website} target="_blank" rel="noopener noreferrer" class="contact-link">
                  Website besuchen &rarr;
                </a>
              )}
              {teacher.contact?.instagram && (
                <a
                  href={`https://instagram.com/${teacher.contact.instagram.replace('@', '')}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="contact-link"
                >
                  @{teacher.contact.instagram.replace('@', '')} auf Instagram
                </a>
              )}
            </div>
          </div>
        )}
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .back-link:hover {
    text-decoration: underline;
  }

  /* ====== Single-column portrait layout ====== */
  .profile {
    max-width: 700px;
    margin: 0 auto;
  }

  .profile-hero {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .profile-hero :global(.profile-photo) {
    max-width: 100%;
    max-height: 70vh;
    width: auto;
    height: auto;
    display: block;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .profile-avatar {
    width: 180px;
    height: 180px;
    border-radius: 12px;
    background: var(--gradient-hero);
    color: white;
    font-size: 4rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ====== Intro block ====== */
  .profile-intro {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #eee;
  }

  .profile-name {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .profile-styles {
    font-size: 1.15rem;
    color: var(--color-primary);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .profile-school {
    font-size: 0.95rem;
    color: var(--color-text-muted, #666);
    margin: 0;
  }

  .profile-school a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .profile-school a:hover {
    text-decoration: underline;
  }

  /* ====== Bio ====== */
  .profile-bio {
    font-size: 1.05rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  .profile-bio :global(p) {
    margin-bottom: 1rem;
  }
  .profile-bio :global(a) {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .profile-bio :global(a:hover) {
    text-decoration: underline;
  }
  .profile-bio :global(strong) {
    font-weight: 600;
  }
  .profile-bio :global(ul),
  .profile-bio :global(ol) {
    margin-left: 1.25rem;
    margin-bottom: 1rem;
  }

  /* ====== Section blocks (Kurse, Kontakt) ====== */
  .profile-section {
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #eee;
  }

  .profile-section-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .kurse-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .kurs-item-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .kurs-item {
    background: var(--color-neutral-light, #faf9f7);
    border-radius: 8px;
    padding: 1rem;
    border-left: 3px solid var(--color-primary);
    transition: box-shadow 0.2s;
  }
  .kurs-item:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .kurs-item-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }

  .kurs-item h4 {
    font-size: 1rem;
    margin: 0;
  }

  .kurs-level {
    font-size: 0.65rem;
    font-weight: 600;
    color: white;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .kurs-item-meta {
    font-size: 0.85rem;
    color: #666;
  }

  .kurs-style {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-secondary-terracotta);
    background: rgba(230, 81, 0, 0.08);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    margin-top: 0.3rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-link {
    display: inline-block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .contact-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .profile-name {
      font-size: 1.6rem;
    }
    .profile-styles {
      font-size: 1rem;
    }
  }
</style>
