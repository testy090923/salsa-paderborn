---
/**
 * Dynamic event detail page.
 *
 * Fetches a single event from Sanity by slug and renders
 * a full detail view with date, location, description, and
 * optional Portable Text details block.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SanityImage from '../../components/SanityImage.astro';
import { PortableText } from 'astro-portabletext';
import { sanityClient, urlFor } from '../../lib/sanity';
import { eventBySlugQuery } from '../../lib/queries';

export async function getStaticPaths() {
  const events = await sanityClient.fetch(`*[_type == "event"]{ slug }`);
  return events
    .filter((item: any) => item.slug?.current)
    .map((item: any) => ({
      params: { slug: item.slug.current },
    }));
}

const { slug } = Astro.params;
const event = await sanityClient.fetch(eventBySlugQuery, { slug });

if (!event) {
  return Astro.redirect('/events');
}

// Format dates in German locale
const dateObj = new Date(event.date);
const formattedDate = dateObj.toLocaleDateString('de-DE', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const formattedTime = dateObj.toLocaleTimeString('de-DE', {
  hour: '2-digit',
  minute: '2-digit',
});

// Format end date if available (multi-day events)
let formattedEndDate: string | null = null;
if (event.endDate) {
  const endObj = new Date(event.endDate);
  formattedEndDate = endObj.toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Short date for multi-day range display
const shortStartDate = dateObj.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
});

// Category color coding (Brand Guide)
const categoryColors: Record<string, string> = {
  Party: 'var(--color-secondary-terracotta)',
  Social: 'var(--color-primary)',
  Festival: 'var(--color-secondary-gold)',
  Sonstiges: '#666',
};
const tagColor = categoryColors[event.category ?? ''] ?? '#666';

// Schema.org Event structured data
const siteUrl = 'https://salsa-paderborn.de';
const eventImageUrl = event.image ? urlFor(event.image)?.width(1200).url() : undefined;

const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.title,
  startDate: event.date,
  ...(event.endDate && { endDate: event.endDate }),
  description: event.description ?? undefined,
  url: `${siteUrl}/events/${event.slug?.current}`,
  ...(eventImageUrl && { image: eventImageUrl }),
  ...(event.location && {
    location: {
      '@type': 'Place',
      name: event.location,
      ...(event.city && {
        address: {
          '@type': 'PostalAddress',
          addressLocality: event.city,
        },
      }),
    },
  }),
  ...(event.organizer?.name && {
    organizer: {
      '@type': 'Organization',
      name: event.organizer.name,
      ...(event.organizer.slug?.current && {
        url: `${siteUrl}/tanzschulen/${event.organizer.slug.current}`,
      }),
    },
  }),
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
};
---

<BaseLayout title={`${event.title} – Salsa Paderborn`}>
  <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} slot="head" />
  <div class="page-header">
    <h1>{event.title}</h1>
    <p>{formattedDate} · {formattedTime} Uhr</p>
  </div>

  <section class="section">
    <div class="container">
      <a href="/events" class="back-link">&larr; Alle Events</a>

      <div class="detail-card">
        {event.image && (
          <div class="detail-image">
            <SanityImage source={event.image} alt={event.title} width={800} />
          </div>
        )}

        <div class="detail-body">
          <div class="detail-tags">
            {event.category && (
              <span class="category-tag" style={`background: ${tagColor}`}>{event.category}</span>
            )}
          </div>

          <div class="detail-meta">
            <div class="meta-row">
              <span class="meta-label">Datum</span>
              <span class="meta-value">
                {formattedEndDate
                  ? `${shortStartDate} – ${formattedEndDate}`
                  : formattedDate}
              </span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Uhrzeit</span>
              <span class="meta-value">{formattedTime} Uhr</span>
            </div>
            {event.location && (
              <div class="meta-row">
                <span class="meta-label">Ort</span>
                <span class="meta-value">
                  {event.location}{event.city ? `, ${event.city}` : ''}
                </span>
              </div>
            )}
            {event.price && (
              <div class="meta-row">
                <span class="meta-label">Eintritt</span>
                <span class="meta-value price">{event.price}</span>
              </div>
            )}
            {event.organizer?.name && (
              <div class="meta-row">
                <span class="meta-label">Veranstalter</span>
                <span class="meta-value">
                  {event.organizer.slug?.current ? (
                    <a href={`/tanzschulen/${event.organizer.slug.current}`}>{event.organizer.name}</a>
                  ) : (
                    event.organizer.name
                  )}
                </span>
              </div>
            )}
          </div>

          {event.description && (
            <div class="detail-description">
              <p>{event.description}</p>
            </div>
          )}

          {event.details && (
            <div class="detail-richtext">
              <PortableText value={event.details} />
            </div>
          )}

          {event.link && (
            <a href={event.link} target="_blank" rel="noopener noreferrer" class="btn btn-primary detail-cta">
              Mehr Infos &rarr;
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    margin-bottom: var(--space-lg);
  }
  .back-link:hover {
    text-decoration: underline;
  }

  .detail-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .detail-image {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .detail-image :global(img) {
    max-width: 100%;
    max-height: 85vh;
    width: auto;
    height: auto;
    display: block;
  }

  .detail-body {
    padding: 1.5rem;
  }

  .detail-tags {
    margin-bottom: 1rem;
  }

  .category-tag {
    display: inline-block;
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
    padding: var(--space-md);
    background: var(--color-neutral-light);
    border-radius: var(--radius-sm);
  }

  .meta-row {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .meta-label {
    min-width: 100px;
    font-weight: 600;
    color: #666;
    flex-shrink: 0;
  }

  .meta-value {
    color: #333;
  }
  .meta-value.price {
    font-weight: 600;
    color: var(--color-primary);
  }
  .meta-value a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .meta-value a:hover {
    text-decoration: underline;
  }

  .detail-description {
    margin-bottom: 1.5rem;
  }
  .detail-description p {
    font-size: 1rem;
    color: #444;
    line-height: 1.7;
  }

  .detail-richtext {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    color: #444;
    line-height: 1.7;
  }
  .detail-richtext :global(p) {
    margin-bottom: 0.75rem;
  }
  .detail-richtext :global(strong) {
    font-weight: 600;
  }
  .detail-richtext :global(a) {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .detail-richtext :global(a:hover) {
    text-decoration: underline;
  }
  .detail-richtext :global(ul),
  .detail-richtext :global(ol) {
    margin-left: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .detail-cta {
    margin-top: 0.5rem;
  }

  @media (max-width: 600px) {
    .meta-row {
      flex-direction: column;
      gap: 0.15rem;
    }
    .meta-label {
      min-width: auto;
      font-size: 0.8rem;
    }
  }
</style>
