---
/**
 * Dynamic course detail page.
 *
 * Fetches a single course from Sanity by slug and renders
 * level, style, schedule, teacher/school references, and description.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SanityImage from '../../components/SanityImage.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { courseBySlugQuery } from '../../lib/queries';

export async function getStaticPaths() {
  const courses = await sanityClient.fetch(`*[_type == "course"]{ slug }`);
  return courses
    .filter((item: any) => item.slug?.current)
    .map((item: any) => ({
      params: { slug: item.slug.current },
    }));
}

const { slug } = Astro.params;
const course = await sanityClient.fetch(courseBySlugQuery, { slug });

if (!course) {
  return Astro.redirect('/kurse');
}

// Level color coding (Brand Guide)
const levelColors: Record<string, string> = {
  'Anfänger': 'var(--color-success)',
  'Mittelstufe': 'var(--color-secondary-terracotta)',
  'Fortgeschritten': 'var(--color-primary)',
  'Alle': 'var(--color-info)',
};
const tagColor = levelColors[course.level ?? ''] ?? '#666';

// Style color coding (Brand Guide)
const styleColors: Record<string, string> = {
  'Salsa': 'var(--color-primary)',
  'Bachata': 'var(--color-secondary-terracotta)',
  'Kizomba': 'var(--color-info)',
  'Sonstiges': '#666',
};
const styleColor = styleColors[course.style ?? ''] ?? '#666';

// Format start date if available
let formattedStartDate: string | null = null;
if (course.startDate) {
  const startObj = new Date(course.startDate);
  formattedStartDate = startObj.toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Schema.org Course structured data
const siteUrl = 'https://salsa-paderborn.de';
const courseImageUrl = course.image ? urlFor(course.image)?.width(1200).url() : undefined;

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.title,
  description: course.description ?? undefined,
  url: `${siteUrl}/kurse/${course.slug?.current}`,
  ...(courseImageUrl && { image: courseImageUrl }),
  courseMode: 'Onsite',
  ...(course.schedule && {
    hasCourseInstance: {
      '@type': 'CourseInstance',
      courseMode: 'Onsite',
      ...(course.schedule && { schedule: course.schedule }),
      ...(course.location && {
        location: {
          '@type': 'Place',
          name: course.location,
        },
      }),
    },
  }),
  provider: {
    '@type': 'Organization',
    name: course.school?.name ?? course.teacher?.name ?? 'Salsa Paderborn',
    ...(course.school?.slug?.current && {
      url: `${siteUrl}/tanzschulen/${course.school.slug.current}`,
    }),
  },
  ...(course.teacher?.name && {
    instructor: {
      '@type': 'Person',
      name: course.teacher.name,
      ...(course.teacher.slug?.current && {
        url: `${siteUrl}/lehrer/${course.teacher.slug.current}`,
      }),
    },
  }),
};
---

<BaseLayout title={`${course.title} – Salsa Paderborn`}>
  <script type="application/ld+json" set:html={JSON.stringify(courseJsonLd)} slot="head" />
  <div class="page-header">
    <h1>{course.title}</h1>
    {course.schedule && <p>{course.schedule}</p>}
  </div>

  <section class="section">
    <div class="container">
      <a href="/kurse" class="back-link">&larr; Alle Kurse</a>

      <div class="detail-card">
        {course.image && (
          <div class="detail-image">
            <SanityImage source={course.image} alt={course.title} width={800} />
          </div>
        )}

        <div class="detail-body">
          <div class="detail-tags">
            {course.level && (
              <span class="level-tag" style={`background: ${tagColor}`}>{course.level}</span>
            )}
            {course.style && (
              <span class="style-tag" style={`background: ${styleColor}`}>{course.style}</span>
            )}
            {course.category && (
              <span class="category-label">{course.category}</span>
            )}
          </div>

          {course.partnerRequired === false && (
            <span class="partner-badge">Kein Partner nötig</span>
          )}

          <div class="detail-meta">
            {course.schedule && (
              <div class="meta-row">
                <span class="meta-label">Zeitplan</span>
                <span class="meta-value">{course.schedule}</span>
              </div>
            )}
            {formattedStartDate && (
              <div class="meta-row">
                <span class="meta-label">Start</span>
                <span class="meta-value">{formattedStartDate}</span>
              </div>
            )}
            {course.location && (
              <div class="meta-row">
                <span class="meta-label">Ort</span>
                <span class="meta-value">{course.location}</span>
              </div>
            )}
            {course.teacher?.name && (
              <div class="meta-row">
                <span class="meta-label">Lehrer:in</span>
                <span class="meta-value">
                  {course.teacher.slug?.current ? (
                    <a href={`/lehrer/${course.teacher.slug.current}`}>{course.teacher.name}</a>
                  ) : (
                    course.teacher.name
                  )}
                </span>
              </div>
            )}
            {course.school?.name && (
              <div class="meta-row">
                <span class="meta-label">Tanzschule</span>
                <span class="meta-value">
                  {course.school.slug?.current ? (
                    <a href={`/tanzschulen/${course.school.slug.current}`}>{course.school.name}</a>
                  ) : (
                    course.school.name
                  )}
                </span>
              </div>
            )}
          </div>

          {course.description && (
            <div class="detail-description">
              <h2>Beschreibung</h2>
              <p>{course.description}</p>
            </div>
          )}

          {course.teacher?.name && (
            <div class="teacher-preview">
              <div class="teacher-avatar">
                {course.teacher.photo ? (
                  <SanityImage
                    source={course.teacher.photo}
                    alt={course.teacher.name}
                    width={48}
                    height={48}
                    class="teacher-photo"
                  />
                ) : (
                  <span class="teacher-letter">{course.teacher.name.charAt(0)}</span>
                )}
              </div>
              <div class="teacher-info">
                <strong>{course.teacher.name}</strong>
                {course.teacher.styles && (
                  <span class="teacher-styles">{course.teacher.styles.join(', ')}</span>
                )}
              </div>
              {course.teacher.slug?.current && (
                <a href={`/lehrer/${course.teacher.slug.current}`} class="teacher-profile-link">
                  Profil &rarr;
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    margin-bottom: var(--space-lg);
  }
  .back-link:hover {
    text-decoration: underline;
  }

  .detail-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .detail-image {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .detail-image :global(img) {
    max-width: 100%;
    max-height: 85vh;
    width: auto;
    height: auto;
    display: block;
  }

  .detail-body {
    padding: 1.5rem;
  }

  .detail-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .level-tag,
  .style-tag {
    display: inline-block;
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .category-label {
    font-size: 0.7rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .partner-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-success);
    background: rgba(46, 125, 50, 0.08);
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  .detail-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--color-neutral-light);
    border-radius: var(--radius-sm);
  }

  .meta-row {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .meta-label {
    min-width: 100px;
    font-weight: 600;
    color: #666;
    flex-shrink: 0;
  }

  .meta-value {
    color: #333;
  }
  .meta-value a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .meta-value a:hover {
    text-decoration: underline;
  }

  .detail-description {
    margin-bottom: 1.5rem;
  }
  .detail-description h2 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }
  .detail-description p {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.7;
  }

  .teacher-preview {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--color-neutral-light);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-primary);
  }

  .teacher-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--gradient-hero);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .teacher-avatar :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .teacher-letter {
    color: white;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .teacher-info {
    flex: 1;
  }
  .teacher-info strong {
    display: block;
    font-size: 0.95rem;
  }
  .teacher-styles {
    font-size: 0.8rem;
    color: #666;
  }

  .teacher-profile-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
  }
  .teacher-profile-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .meta-row {
      flex-direction: column;
      gap: 0.15rem;
    }
    .meta-label {
      min-width: auto;
      font-size: 0.8rem;
    }
    .teacher-preview {
      flex-wrap: wrap;
    }
  }
</style>
