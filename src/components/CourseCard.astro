---
/**
 * CourseCard -- Reusable card for the course listing page.
 * Styled according to Brand Guide: Sansita headings, brand colors, card shadows.
 */
interface Props {
  course: {
    title: string;
    slug: { current: string };
    category?: string;
    level?: string;
    style?: string;
    schedule?: string;
    location?: string;
    description?: string;
    partnerRequired?: boolean;
    image?: any;
    teacher?: { name: string; slug?: { current: string } };
    school?: { name: string; slug?: { current: string } };
  };
}

const { course } = Astro.props;

// Level color coding (Brand Guide)
const levelColors: Record<string, string> = {
  'Anfänger': 'var(--color-success)',
  'Mittelstufe': 'var(--color-secondary-terracotta)',
  'Fortgeschritten': 'var(--color-primary)',
  'Alle': 'var(--color-info)',
};
const tagColor = levelColors[course.level ?? ''] ?? '#666';
---

<a href={`/kurse/${course.slug.current}`} class="kurs-card-link">
  <article class="kurs-card">
    <div class="kurs-header">
      {course.level && (
        <span class="kurs-tag" style={`background: ${tagColor}`}>{course.level}</span>
      )}
      {course.category && course.category !== course.level && (
        <span class="kurs-category">{course.category}</span>
      )}
    </div>
    <h3>{course.title}</h3>
    {course.schedule && (
      <p class="kurs-schedule">{course.schedule}</p>
    )}
    <p class="kurs-meta">
      {course.location && <span>{course.location}</span>}
      {course.teacher?.name && (
        <span>
          {' '}&middot;{' '}
          {course.teacher.slug?.current ? (
            <a href={`/lehrer/${course.teacher.slug.current}`} class="kurs-teacher-link">
              {course.teacher.name}
            </a>
          ) : (
            course.teacher.name
          )}
        </span>
      )}
    </p>
    {course.school?.name && (
      <p class="kurs-school">{course.school.name}</p>
    )}
    {course.description && (
      <p class="kurs-desc">{course.description}</p>
    )}
    {course.partnerRequired === false && (
      <span class="kurs-partner-info">Kein Partner nötig</span>
    )}
  </article>
</a>

<style>
  .kurs-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .kurs-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
    transition: box-shadow 200ms ease-in-out, transform 200ms ease-in-out;
  }

  .kurs-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .kurs-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .kurs-tag {
    display: inline-block;
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 2px var(--space-sm);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .kurs-category {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .kurs-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 2px;
    color: var(--color-neutral-dark);
  }

  .kurs-schedule {
    font-size: 0.85rem;
    font-weight: 600;
    color: #444;
    margin-bottom: var(--space-xs);
  }

  .kurs-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .kurs-teacher-link {
    color: var(--color-primary);
    text-decoration: none;
  }

  .kurs-teacher-link:hover {
    text-decoration: underline;
  }

  .kurs-school {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .kurs-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .kurs-partner-info {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-success);
    background: rgba(46, 125, 50, 0.08);
    padding: 2px var(--space-sm);
    border-radius: 4px;
    margin-top: var(--space-sm);
  }
</style>
