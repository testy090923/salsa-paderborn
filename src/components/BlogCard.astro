---
/**
 * BlogCard -- Reusable card for the blog/news listing page.
 * Styled according to Brand Guide: Sansita headings, brand colors, card shadows.
 */
import SanityImage from './SanityImage.astro';

interface Props {
  post: {
    title: string;
    slug: { current: string };
    publishedAt?: string;
    excerpt?: string;
    image?: any;
    tags?: string[];
    author?: { name: string; slug?: { current: string } };
  };
}

const { post } = Astro.props;

// Format published date in German locale
let formattedDate = '';
if (post.publishedAt) {
  const dateObj = new Date(post.publishedAt);
  formattedDate = dateObj.toLocaleDateString('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<a href={`/news/${post.slug.current}`} class="blog-card-link">
  <article class="blog-card">
    <div class="blog-card-image">
      {post.image ? (
        <SanityImage
          source={post.image}
          alt={post.title}
          width={600}
          height={340}
          class="blog-img"
        />
      ) : (
        <div class="blog-img-placeholder">
          <span>{post.title.charAt(0)}</span>
        </div>
      )}
    </div>
    <div class="blog-card-body">
      {formattedDate && (
        <p class="blog-date">{formattedDate}</p>
      )}
      <h3>{post.title}</h3>
      {post.excerpt && (
        <p class="blog-excerpt">{post.excerpt}</p>
      )}
      <div class="blog-card-footer">
        {post.tags && post.tags.length > 0 && (
          <div class="blog-tags">
            {post.tags.map((tag) => (
              <span class="blog-tag">{tag}</span>
            ))}
          </div>
        )}
        {post.author?.name && (
          <p class="blog-author">von {post.author.name}</p>
        )}
      </div>
    </div>
  </article>
</a>

<style>
  .blog-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .blog-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: box-shadow 200ms ease-in-out, transform 200ms ease-in-out;
  }

  .blog-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .blog-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-neutral-light);
  }

  .blog-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-img-placeholder {
    width: 100%;
    height: 100%;
    background: var(--gradient-hero);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 700;
    font-family: var(--font-heading);
    opacity: 0.8;
  }

  .blog-card-body {
    padding: var(--space-lg);
  }

  .blog-date {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: var(--space-sm);
  }

  .blog-card-body h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
    color: var(--color-neutral-dark);
  }

  .blog-excerpt {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    margin-bottom: var(--space-md);
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .blog-tag {
    font-size: 0.7rem;
    background: var(--color-neutral-light);
    padding: 2px var(--space-sm);
    border-radius: 4px;
    color: var(--color-neutral-dark);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 600;
  }

  .blog-author {
    font-size: 0.8rem;
    color: #999;
  }
</style>
