---
/**
 * EventCard -- Full event card for listing pages.
 * Styled according to Brand Guide: Sansita headings, brand colors, card shadows.
 */
interface Props {
  event: {
    title: string;
    slug: { current: string };
    date: string;
    endDate?: string;
    category?: string;
    location?: string;
    city?: string;
    description?: string;
    price?: string;
    image?: any;
    organizer?: { name: string; slug?: { current: string } };
  };
}

const { event } = Astro.props;

// Format date in German locale
const dateObj = new Date(event.date);
const formattedDate = dateObj.toLocaleDateString('de-DE', {
  weekday: 'short',
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
const formattedTime = dateObj.toLocaleTimeString('de-DE', {
  hour: '2-digit',
  minute: '2-digit',
});

// Category color coding (Brand Guide)
const categoryColors: Record<string, string> = {
  Party: 'var(--color-secondary-terracotta)',
  Social: 'var(--color-primary)',
  Festival: 'var(--color-secondary-gold)',
  Sonstiges: '#666',
};
const tagColor = categoryColors[event.category ?? ''] ?? '#666';
// Gold badge needs dark text for contrast
const tagTextColor = event.category === 'Festival' ? 'var(--color-neutral-dark)' : 'var(--color-white)';
---

<a href={`/events/${event.slug.current}`} class="event-card-link">
  <article class="event-card-full">
    <div class="event-date-block">
      <span class="event-day">{formattedDate}</span>
      <span class="event-time">{formattedTime} Uhr</span>
    </div>
    <div class="event-content">
      {event.category && (
        <span class="event-tag" style={`background: ${tagColor}; color: ${tagTextColor}`}>{event.category}</span>
      )}
      <h3>{event.title}</h3>
      <p class="event-location">
        {event.location}{event.city ? `, ${event.city}` : ''}
      </p>
      {event.description && (
        <p class="event-desc">{event.description}</p>
      )}
      {event.price && (
        <p class="event-price">{event.price}</p>
      )}
      {event.organizer?.name && (
        <p class="event-organizer">Veranstalter: {event.organizer.name}</p>
      )}
    </div>
  </article>
</a>

<style>
  .event-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .event-card-full {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
    transition: box-shadow 200ms ease-in-out, transform 200ms ease-in-out;
  }

  .event-card-full:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .event-date-block {
    min-width: 110px;
    flex-shrink: 0;
  }

  .event-day {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-neutral-dark);
  }

  .event-time {
    display: block;
    font-size: 0.8rem;
    color: #666;
    margin-top: 2px;
  }

  .event-content {
    flex: 1;
  }

  .event-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 2px var(--space-sm);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .event-content h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 2px;
    color: var(--color-neutral-dark);
  }

  .event-location {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: var(--space-sm);
  }

  .event-desc {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
  }

  .event-price {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: var(--space-xs);
  }

  .event-organizer {
    font-size: 0.8rem;
    color: #666;
    margin-top: var(--space-xs);
  }

  @media (max-width: 640px) {
    .event-card-full {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
