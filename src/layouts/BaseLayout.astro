---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
}

const { title, description = 'Salsa Paderborn – Deine Anlaufstelle für Salsa, Bachata & Kizomba in Paderborn und Umgebung', image, url } = Astro.props;

const siteUrl = 'https://salsa-paderborn.de';
const canonicalUrl = url ?? `${siteUrl}${Astro.url.pathname}`;
const ogImage = image ?? `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Self-hosted fonts (DSGVO-konform, kein Google CDN) -->
    <link rel="preload" href="/fonts/sansita-700-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-sans-3-latin.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>

    <!-- Structured data slot for JSON-LD -->
    <slot name="head" />

    <style is:global>
      /* ==========================================================================
         Font-Face Declarations
         ========================================================================== */

      /* Sansita – Headlines */
      @font-face {
        font-family: 'Sansita';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/sansita-400-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
      @font-face {
        font-family: 'Sansita';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/sansita-400-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Sansita';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/fonts/sansita-700-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
      @font-face {
        font-family: 'Sansita';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/fonts/sansita-700-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }

      /* Source Sans 3 – Body text (variable font, supports 200-900 weights) */
      @font-face {
        font-family: 'Source Sans 3';
        font-style: normal;
        font-weight: 300 600;
        font-display: swap;
        src: url('/fonts/source-sans-3-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
      @font-face {
        font-family: 'Source Sans 3';
        font-style: normal;
        font-weight: 300 600;
        font-display: swap;
        src: url('/fonts/source-sans-3-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }

      /* ==========================================================================
         Design Tokens (CSS Custom Properties from Brand Guide)
         ========================================================================== */

      :root {
        /* Colors – Primary (Havana Lights: Magenta on Light) */
        --color-primary: #A8135A;
        --color-primary-dark: #8A0F4A;

        /* Colors – Secondary */
        --color-secondary-gold: #E8A838;
        --color-secondary-terracotta: #D94F9A;

        /* Colors – Neutral */
        --color-neutral-dark: #1A1A2E;
        --color-neutral-light: #FAF7F2;
        --color-white: #FFFFFF;

        /* Colors – Text */
        --color-text-secondary: #555;
        --color-text-muted: #666;

        /* Colors – Functional */
        --color-success: #2E7D32;
        --color-warning: #F9A825;
        --color-error: #C62828; /* stays red for semantic clarity */
        --color-info: #1565C0;

        /* Typography */
        --font-heading: 'Sansita', 'Arial Black', sans-serif;
        --font-body: 'Source Sans 3', 'Segoe UI', system-ui, sans-serif;

        /* Spacing (8px grid) */
        --space-xs: 4px;
        --space-sm: 8px;
        --space-md: 16px;
        --space-lg: 24px;
        --space-xl: 32px;
        --space-2xl: 48px;
        --space-3xl: 64px;
        --space-4xl: 96px;

        /* Shadows */
        --shadow-card: 0 2px 8px rgba(26, 26, 46, 0.08);
        --shadow-card-hover: 0 4px 16px rgba(26, 26, 46, 0.12);

        /* Border Radius */
        --radius-sm: 8px;
        --radius-md: 12px;

        /* Gradients */
        --gradient-hero: linear-gradient(135deg, #A8135A, #6B1D5E);
        --gradient-dark: linear-gradient(180deg, #1A1A2E, #2D2D44);
      }

      /* ==========================================================================
         Reset & Base Styles
         ========================================================================== */

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 16px;
        line-height: 1.6;
        color: var(--color-neutral-dark);
        background: var(--color-neutral-light);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ==========================================================================
         Accessibility: Focus Styles
         ========================================================================== */

      :focus-visible {
        outline: 3px solid var(--color-secondary-gold);
        outline-offset: 2px;
      }

      /* ==========================================================================
         Accessibility: Skip Link
         ========================================================================== */

      .skip-link {
        position: absolute;
        top: -100%;
        left: 0;
        padding: 8px 16px;
        background: var(--color-primary);
        color: var(--color-white);
        z-index: 200;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
      }

      .skip-link:focus {
        top: 0;
      }

      /* Headings – all use Sansita */
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        line-height: 1.2;
      }

      h1 {
        font-weight: 700;
        font-size: 2rem;
        line-height: 1.2;
      }

      h2 {
        font-weight: 700;
        font-size: 1.625rem;
        line-height: 1.25;
      }

      h3 {
        font-weight: 700;
        font-size: 1.375rem;
        line-height: 1.3;
      }

      h4 {
        font-weight: 700;
        font-size: 1.125rem;
        line-height: 1.3;
      }

      /* Desktop heading sizes */
      @media (min-width: 1024px) {
        h1 { font-size: 3rem; }
        h2 { font-size: 2.25rem; }
        h3 { font-size: 1.75rem; }
        h4 { font-size: 1.375rem; }
      }

      /* ==========================================================================
         Layout Utilities
         ========================================================================== */

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 var(--space-md);
      }

      @media (min-width: 640px) {
        .container {
          padding: 0 var(--space-xl);
        }
      }

      @media (min-width: 1024px) {
        .container {
          max-width: 1024px;
        }
      }

      @media (min-width: 1280px) {
        .container {
          max-width: 1200px;
        }
      }

      .section {
        padding: var(--space-2xl) 0;
      }

      @media (min-width: 1024px) {
        .section {
          padding: var(--space-3xl) 0;
        }
      }

      .section-warm {
        background: var(--color-neutral-light);
      }

      .section-title {
        font-family: var(--font-heading);
        font-size: 1.625rem;
        font-weight: 700;
        margin-bottom: var(--space-sm);
        text-align: center;
      }

      @media (min-width: 1024px) {
        .section-title {
          font-size: 2.25rem;
        }
      }

      .section-sub {
        text-align: center;
        color: var(--color-text-muted);
        font-size: 1rem;
        margin-bottom: var(--space-xl);
      }

      /* ==========================================================================
         Page Header (subpages)
         ========================================================================== */

      .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: var(--space-2xl) var(--space-md);
        text-align: center;
      }

      .page-header h1 {
        font-family: var(--font-heading);
        font-size: 2rem;
        margin-bottom: var(--space-sm);
      }

      @media (min-width: 1024px) {
        .page-header h1 {
          font-size: 3rem;
        }
        .page-header {
          padding: var(--space-3xl) var(--space-md);
        }
      }

      .page-header p {
        opacity: 0.9;
        font-size: 1.05rem;
        max-width: 600px;
        margin: 0 auto;
      }

      /* ==========================================================================
         Buttons
         ========================================================================== */

      .btn {
        display: inline-block;
        padding: 12px 24px;
        border-radius: var(--radius-sm);
        text-decoration: none;
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 1rem;
        line-height: 1;
        cursor: pointer;
        border: 2px solid transparent;
        transition: background 200ms ease-in-out, color 200ms ease-in-out, transform 200ms ease-in-out, box-shadow 200ms ease-in-out;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-primary {
        background: var(--color-primary);
        color: var(--color-white);
        border-color: var(--color-primary);
      }

      .btn-primary:hover {
        background: var(--color-primary-dark);
        border-color: var(--color-primary-dark);
        box-shadow: 0 4px 12px rgba(168, 19, 90, 0.3);
      }

      .btn-secondary {
        background: transparent;
        color: var(--color-primary);
        border-color: var(--color-primary);
      }

      .btn-secondary:hover {
        background: var(--color-primary);
        color: var(--color-white);
      }

      /* Secondary button on dark/gradient backgrounds */
      .btn-secondary-light {
        background: transparent;
        color: var(--color-white);
        border-color: var(--color-white);
      }

      .btn-secondary-light:hover {
        background: var(--color-white);
        color: var(--color-primary);
      }

      /* ==========================================================================
         Links
         ========================================================================== */

      .see-all {
        display: block;
        text-align: center;
        margin-top: var(--space-lg);
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-primary);
        text-decoration: none;
      }

      .see-all:hover {
        text-decoration: underline;
      }

      /* ==========================================================================
         Empty State
         ========================================================================== */

      .empty-state {
        text-align: center;
        color: var(--color-text-muted);
        font-size: 0.95rem;
        padding: var(--space-2xl) 0;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
